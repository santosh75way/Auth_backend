# Server
PORT=8080
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Database (Prisma / PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/auth_db?schema=public"

# JWT
JWT_ACCESS_SECRET="change_me_access_secret"
JWT_REFRESH_SECRET="change_me_refresh_secret"
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=1209600

# Cookies (refresh token cookie)
COOKIE_NAME_REFRESH=refresh_token
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

# SMTP Email
# Gmail — use an App Password (NOT your Gmail password)
#   Create one at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16_char_app_password
SMTP_FROM="Auth App <your_email@gmail.com>"

# Frontend URL used in password-reset email link
FRONTEND_URL=http://localhost:5173